# ── LLM 配置 ─────────────────────────────────────────────────────────────────
# 选择 LLM provider: gemini（默认，免费）| groq（备用，免费）| ollama（本地，离线）
LLM_PROVIDER=gemini

# Google Gemini API Key — 免费注册获取: https://aistudio.google.com/apikey
# 推荐模型: gemini-2.0-flash（快速，免费）或 gemini-1.5-pro（质量更高）
GOOGLE_API_KEY=AIza_your_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq API Key — 备用，免费: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Ollama 本地模型（LLM_PROVIDER=ollama 时使用，需先运行: ollama pull llama3.1:8b）
OLLAMA_MODEL=llama3.1:8b

# ── 数据库 ────────────────────────────────────────────────────────────────────
# ChromaDB 目录（当前阶段）
CHROMA_DIR=./chroma_db

# PostgreSQL 连接（Phase 4 pgvector 迁移后使用）
# DATABASE_URL=postgresql://user:password@localhost:5432/sdgzero

# ── 外部调研 (Step 3 - ResearchAgent) ─────────────────────────────────────────
# Tavily API Key — 免费注册获取: https://tavily.com
# 免费额度: 1000次/月，每次用户搜索消耗 20次（20家公司并行调研）
TAVILY_API_KEY=tvly_your_key_here

# ── API 服务 (Phase 3) ────────────────────────────────────────────────────────
# Sessions directory (JSON files, git-ignored)
SESSIONS_DIR=./sessions

# Report static asset paths:
#   "relative" (default) = ../static/... works for file:// direct open
#   "server"             = /static/... works when served by FastAPI
REPORT_STATIC_BASE=server

# Frontend URL for CORS (production Vercel URL)
# FRONTEND_URL=https://your-app.vercel.app

# ── 日志 ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
